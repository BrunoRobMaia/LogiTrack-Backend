# 🔧 Configurações específicas para Docker
# Use variáveis de ambiente para dados sensíveis
spring.datasource.url=sua_url_aqui
spring.datasource.username=suas_credenciais_aqui
spring.datasource.password=suas_credenciais_aqui
spring.datasource.driver-class-name=org.postgresql.Driver

# 🔧 Configurações do JPA/Hibernate para Docker
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.open-in-view=false

# 🌐 CORS para desenvolvimento em Docker
spring.web.cors.allowed-origins=${SPRING_WEB_CORS_ALLOWED_ORIGINS:http://localhost:3000,http://localhost:4200,http://localhost:8080}
spring.web.cors.allowed-methods=GET,POST,PUT,DELETE,OPTIONS
spring.web.cors.allowed-headers=*
spring.web.cors.allow-credentials=true

# 📝 Logging
logging.level.com.example.logitrack=${LOGGING_LEVEL:INFO}
logging.level.org.springframework.security=${SECURITY_LOG_LEVEL:DEBUG}

# 🖥️ Server
server.port=${SERVER_PORT:8080}
