# 📊 Configurações do Banco de Dados PostgreSQL
# Use variáveis de ambiente para dados sensíveis
spring.datasource.url=jdbc:postgresql://localhost:5432/logitrack
spring.datasource.username=suas_credenciais_aqui
spring.datasource.password=suas_credenciais_aqui
spring.datasource.driver-class-name=org.postgresql.Driver

# 🔧 Configurações do JPA/Hibernate
spring.jpa.hibernate.ddl-auto=validate
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.open-in-view=false

# 🌐 Configurações de CORS (para frontend)
spring.web.cors.allowed-origins=http://localhost:3000
spring.web.cors.allowed-methods=GET,POST,PUT,DELETE,OPTIONS
spring.web.cors.allowed-headers=*
spring.web.cors.allow-credentials=true

# 📝 Configurações de Logging
logging.level.com.example.logitrack=INFO
